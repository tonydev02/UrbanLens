# UrbanLens local development environment.
# All populated values below are development-only defaults. Core startup must
# work without copying this file; create a local .env only to override them.

# PostgreSQL / PostGIS
POSTGRES_DB=urbanlens
POSTGRES_USER=urbanlens
POSTGRES_PASSWORD=urbanlens_dev
POSTGRES_PORT=5432
DATABASE_URL=postgres://urbanlens:urbanlens_dev@postgres:5432/urbanlens

# Rust API
API_HOST=0.0.0.0
API_PORT=8080
API_DATABASE_MAX_CONNECTIONS=5
RUST_LOG=info,urbanlens_api=debug

# Next.js web application and browser-facing API configuration
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql

# Optional: MLIT Real Estate Information Library API key.
# Apply at https://www.reinfolib.mlit.go.jp/api/request/ and keep the issued
# value only in a local ignored .env. Core startup and CI must not require it.
MLIT_REINFOLIB_API_KEY=
